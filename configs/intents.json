{
  "version": "0.1.0",
  "description": "Synthetic, domain-neutral intent library for voice-agent routing.",
  "intents": [
    {
      "id": "stop_contact",
      "label": "User requests no further contact",
      "priority": 120,
      "keywords": [
        "do not call",
        "don't call",
        "stop calling",
        "remove me",
        "unsubscribe",
        "never contact",
        "complaint",
        "report you",
        "别打",
        "不要再联系",
        "投诉"
      ],
      "default_next_node": "safe_stop"
    },
    {
      "id": "privacy_concern",
      "label": "User is concerned about privacy or data use",
      "priority": 105,
      "keywords": [
        "why do you need",
        "my data",
        "privacy",
        "personal information",
        "not comfortable sharing",
        "why are you asking",
        "隐私",
        "为什么问",
        "不方便说"
      ],
      "default_next_node": "privacy_boundary"
    },
    {
