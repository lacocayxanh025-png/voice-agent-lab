{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lacocayxanh025-png/voice-agent-lab/schemas/knowledge_item.schema.json",
  "title": "Voice Agent Lab Knowledge Item",
  "type": "object",
  "required": ["id", "title", "content", "source", "version", "language", "tags"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
    "title": { "type": "string", "minLength": 2 },
    "content": { "type": "string", "minLength": 5 },
    "source": { "type": "string", "minLength": 2 },
    "version": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "pattern": "^[a-z]{2}$" },
    "tags": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    }
  }
}
