{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lacocayxanh025-png/voice-agent-lab/schemas/evaluation_report.schema.json",
  "title": "Voice Agent Lab Synthetic Evaluation Report",
  "type": "object",
  "required": ["version", "report_type", "generated_at", "source", "metrics", "runs"],
  "additionalProperties": true,
  "properties": {
    "version": { "type": "string" },
    "report_type": { "const": "synthetic_evaluation" },
    "generated_at": { "type": "string" },
    "source": {
      "type": "object",
      "required": ["run_count", "case_count", "improvement_record_count"],
      "properties": {
        "run_count": { "type": "integer", "minimum": 0 },
        "case_count": { "type": "integer", "minimum": 0 },
        "improvement_record_count": { "type": "integer", "minimum": 0 }
      }
    },
    "metrics": {
      "type": "object",
      "required": ["total_runs", "total_cases", "passed_cases", "needs_review_cases", "pass_rate"],
      "properties": {
        "total_runs": { "type": "integer", "minimum": 0 },
        "total_cases": { "type": "integer", "minimum": 0 },
        "passed_cases": { "type": "integer", "minimum": 0 },
        "needs_review_cases": { "type": "integer", "minimum": 0 },
        "pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "needs_review_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "high_risk_cases": { "type": "integer", "minimum": 0 },
        "handoff_required_cases": { "type": "integer", "minimum": 0 },
        "handoff_recommended_cases": { "type": "integer", "minimum": 0 },
        "unknown_intent_cases": { "type": "integer", "minimum": 0 },
        "candidate_review_records": { "type": "integer", "minimum": 0 }
      }
    },
    "runs": {
      "type": "array",
      "items": { "type": "object", "required": ["run_id", "total_cases", "pass_rate"] }
    }
  }
}
