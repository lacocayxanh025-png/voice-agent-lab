{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/lacocayxanh025-png/voice-agent-lab/schemas/config_intents.schema.json",
  "title": "Voice Agent Lab Intents Config",
  "type": "object",
  "required": ["version", "description", "intents"],
  "additionalProperties": false,
  "properties": {
    "version": { "type": "string" },
    "description": { "type": "string" },
    "intents": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "label", "priority", "keywords", "default_next_node"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" },
          "label": { "type": "string", "minLength": 3 },
          "priority": { "type": "integer" },
          "keywords": {
            "type": "array",
            "items": { "type": "string" }
          },
          "default_next_node": { "type": "string", "pattern": "^[a-z0-9_\\-]+$" }
        }
      }
    }
  }
}
