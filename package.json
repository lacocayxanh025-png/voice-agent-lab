{
  "name": "voice-agent-lab",
  "version": "0.4.0",
  "description": "A privacy-first lab for testing voice-agent intent routing, escalation rules, and improvement queues with synthetic conversations.",
  "private": false,
  "type": "commonjs",
  "main": "src/engine.js",
  "scripts": {
    "simulate": "node src/simulator.js",
    "persona:run": "node src/persona_runner.js",
    "candidate:generate": "node scripts/generate_candidate_rules.js",
    "queue:export": "node scripts/export_improvement_queue.js",
    "adapter:check": "node tests/voice_adapter.test.js",
    "test": "node tests/engine.test.js && node tests/voice_adapter.test.js && node tests/review_data.test.js && node tests/persona_sparring.test.js && node tests/improvement_workbench.test.js",
    "privacy:check": "node scripts/check_no_sensitive_terms.js"
  },
  "keywords": [
    "voice-agent",
    "conversation-design",
    "intent-routing",
    "contact-center",
    "synthetic-data",
    "codex"
  ],
  "author": "F",
  "homepage": "https://github.com/lacocayxanh025-png/voice-agent-lab#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lacocayxanh025-png/voice-agent-lab.git"
  },
  "bugs": {
    "url": "https://github.com/lacocayxanh025-png/voice-agent-lab/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
